# Database
DATABASE_URL="postgres://postgres:postgres@localhost:5432/taskmarket?sslmode=disable"

# Polling interval in milliseconds
POLLING_INTERVAL_MS=5000

# Chains to index are configured in the "chain_config" table, not via env vars.
# Each row needs: chain_id, rpc_url, contract_address, start_block, enabled.
# Only rows with enabled = true are indexed. See README.md for details.
